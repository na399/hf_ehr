# HF-EHR Environment Configuration
# Copy this file to .env and adjust paths as needed

# Data directories (platform-agnostic)
DATA_DIR=./data
OUTPUT_DIR=./outputs
CACHE_DIR=./cache
LOG_DIR=./logs

# OMOP CDM data location (for conversion)
OMOP_DATA_DIR=./data/Synthea27NjParquet
MEDS_DATA_DIR=./data/synthea_meds
MEDS_READER_DIR=./data/synthea_meds_reader

# Device configuration
# Options: auto (default), cuda, mps, cpu
FORCE_DEVICE=auto

# Single GPU configuration
CUDA_VISIBLE_DEVICES=0  # For L40s or other NVIDIA GPUs

# Training configuration
DEFAULT_BATCH_SIZE=auto  # auto or specific number
DEFAULT_NUM_WORKERS=auto  # auto or specific number

# Tokenizer configuration
TOKENIZER_CACHE_DIR=./cache/tokenizers
TOKENIZER_TYPE=clmbr  # Options: clmbr, desc, cookbook

# Model cache
TRANSFORMERS_CACHE=./cache/transformers
HF_HOME=./cache/huggingface

# Logging
WANDB_PROJECT=hf-ehr-training
WANDB_ENTITY=your-entity-name
WANDB_MODE=online  # online, offline, disabled

# Debug settings
DEBUG=false
VERBOSE=false